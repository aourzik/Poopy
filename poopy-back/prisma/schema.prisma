datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 👤 TABLE UTILISATEUR
model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String        // Pseudo de l'utilisateur
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  // Relations : un utilisateur possède toutes ces données
  stools       Stool[]
  medications  Medication[]
  appointments Appointment[]
  labs         MedicalLab[]
}

// 💩 1. JOURNAL DES SELLES
model Stool {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  count     Int      @default(1)     // Le nombre (stepper)
  bristol   Int                      // Échelle de Bristol (1 à 7)
  blood     Boolean  @default(false) // Présence de sang (Toggle)
  urgency   Boolean  @default(false) // Urgence / Faux besoins (Toggle)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 💊 2. SUIVI DES MÉDICAMENTS / TRAITEMENTS
model Medication {
  id           String   @id @default(uuid())
  name         String   // Pentasa
  dose         String   // 500 mg
  frequency    String   // 2 comprimés · 3×/jour
  totalToday   Int?     // 3 (le chiffre total prévu)
  isInjection  Boolean  @default(false)
  color        String   @default("amber") // coral, amber, green, etc.
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation vers les prises réelles du jour
  logs         MedicationLog[]

  @@index([userId])
}

// Nouvelle table pour enregistrer chaque clic sur "Marquer pris"
model MedicationLog {
  id           String     @id @default(uuid())
  takenAt      DateTime   @default(now())
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

// 🏥 3. RENDEZ-VOUS MÉDICAUX
model Appointment {
  id          String   @id @default(uuid())
  date        DateTime // Contient date + heure
  doctor      String   // Nom du Dr ou Lab
  location    String   // Lieu
  type        String   // Motif du rdv
  notes       String?  // Section "Voir les détails"
  preparation String?  // Section "Préparer la visite"
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 🧪 4. ANALYSES CLINIQUES & BIOLOGIQUES (Le suivi des crises)
model MedicalLab {
  id             String   @id @default(uuid())
  date           DateTime @default(now()) // Date de l'analyse ou du prélèvement
  calprotectin   Float?                   // Calprotectine fécale (mg/kg) -> Optionnel si juste prise de sang
  crp            Float?                   // Protéine C-Réactive (mg/L) -> Optionnel si juste selles
  notes          String?                  // Remarques additionnelles
  
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}